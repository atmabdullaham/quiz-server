# Firebase Admin Credentials (JSON string)
FIREBASE_ADMIN_CREDENTIALS={"type":"service_account","project_id":"your-project-id",...}

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/quiz-platform

# Frontend origins allowed to call the backend API
ALLOWED_ORIGINS=https://kkrf-ctgnorth.web.app,https://your-custom-domain.com

# Node Environment
NODE_ENV=production

# Port (Vercel will set this automatically)
PORT=5000
